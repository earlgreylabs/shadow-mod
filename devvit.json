{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "shadow-mod",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Record observation",
        "description": "(trainee) Log your moderation call without executing it",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/observation"
      },
      {
        "label": "Record review",
        "description": "(senior) Record your independent review of a pending observation",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/review"
      },

      {
        "label": "My ShadowMod stats",
        "description": "View your observation accuracy over time",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/stats"
      },
      {
        "label": "ShadowMod review queue",
        "description": "See posts with pending observations and navigate to them",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/queue"
      }
    ]
  },
  "forms": {
    "observationForm": "/internal/form/observation-submit",
    "reviewForm": "/internal/form/review-submit",
    "queueForm": "/internal/form/queue-submit",
    "statsForm": "/internal/form/stats-submit"
  },
  "scheduler": {
    "tasks": {
      "generate-report": {
        "endpoint": "/internal/cron/generate-report"
      }
    }
  },
  "triggers": {
    "onModAction": "/internal/triggers/mod-action",
    "onAppInstall": "/internal/triggers/app-install"
  },
  "permissions": {
    "redis": true,
    "reddit": true
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  },
  "settings": {
    "subreddit": {
      "reviewers": {
        "type": "string",
        "label": "Reviewer usernames",
        "helpText": "Comma-separated list of Reddit usernames who act as Reviewers for this subreddit (e.g. username1, username2).",
        "defaultValue": ""
      }
    }
  },
  "dev": {
    "subreddit": "shadow_mod_dev"
  }
}
